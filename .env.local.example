# Supabase (obtener en https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...tu_anon_key

# Solo servidor: invitar líderes / crear usuarios (Settings → API → service_role). No la subas al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase local (opcional) ---
# `supabase start` en la raíz del repo. Este proyecto usa puerto API 55321 (evita choque con otro stack en 54321).
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
# ANON / SERVICE_ROLE: salida de `supabase status` o JWT demo estándar de CLI.
# Copia lo anterior a `.env.development.local` para `npm run dev`.
